rules_version = '2';

// NOTE: Full identity-based rules require Firebase Auth, which needs a
// macOS code-signing certificate (keychain-access-groups entitlement).
// Until that is set up, these rules use structural validation + document-ID
// obscurity (UUIDs are 128-bit random — only people who received the link
// can reach a document).
//
// TODO: Re-enable identity-based rules once a development certificate is
// configured in Xcode (Signing & Capabilities → Team).

service cloud.firestore {
  match /databases/{database}/documents {
    match /shared_notes/{noteId} {
      // Anyone who knows the UUID can read (only shared via direct link).
      allow read: if true;

      // Create: must include all required fields.
      allow create: if request.resource.data.keys().hasAll([
        'title', 'content', 'ownerId', 'ownerEmail',
        'collaboratorEmails', 'updatedAt', 'updatedBy', 'updatedByEmail'
      ]);

      // Update: ownerEmail and ownerId cannot be changed after creation
      // (prevents ownership takeover).
      allow update: if request.resource.data.ownerEmail == resource.data.ownerEmail
        && request.resource.data.ownerId == resource.data.ownerId;

      // Delete: open (only reachable by people who know the UUID).
      allow delete: if true;
    }
  }
}
